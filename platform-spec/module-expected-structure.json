  "validatorContract": {
    "description": "How Section S validator (zorbit-cli/scripts/cycles/section-s-structure.ts) consumes this file.",
    "steps": [
      "1. Load this JSON. Build module → expected-structure index.",
      "2. Authenticate as super-admin (B.00 must have passed).",
      "3. Fetch live menu via GET /api/navigation/api/v1/U/<userHashId>/menu.",
      "4. Walk the menu tree. For each node with id matching `modules[*].menuId`, descend.",
      "5. Collect L3 group keys actually present (children with role=group OR children grouped by category).",
      "6. For each `required_groups[i]`: assert present. Missing = 🔴 BLOCKER.",
      "7. For each `required_<group>_items[j]`: assert that one of the L4 leafs under that group has a feRoute matching `<modulePath>/<group>/<item>` OR slug equal to `<item>`. Missing = 🔴 BLOCKER.",
      "8. For each `optional_*_items[j]`: same as above but missing = 🟡 NON-BLOCKER (record + continue).",
      "9. Output report JSON: { module, expected: {groups, items}, actual: {groups, items}, missing_required: [...], missing_optional: [...], pass: bool }.",
      "10. Exit non-zero iff any module has non-empty missing_required."
    ]
  }
